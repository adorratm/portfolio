# Production ortam değişkenleri — Hetzner sunucusunda deploy/.env olarak kopyalayın
# cp deploy/.env.production.example deploy/.env

# ── TTEN Games paylaşımlı nginx (Hetzner) ──
PORTFOLIO_TTEN_NETWORK=ttengamesstudio_ttengamesstudio-network

# ── Host portları (TTEN Games 3000/4000 ile çakışmaz) ──
FRONTEND_HOST_PORT=3100
ADMIN_HOST_PORT=3101
API_HOST_PORT=3102
POSTGRES_HOST_PORT=5433
REDIS_HOST_PORT=6380

# ── Domain URL'leri ──
FRONTEND_URL=https://emrekilic.web.tr
ADMIN_URL=https://admin.emrekilic.web.tr
NEXT_PUBLIC_SITE_URL=https://emrekilic.web.tr
NEXT_PUBLIC_API_URL=https://api.emrekilic.web.tr/api/v1
NEXT_PUBLIC_WS_URL=https://api.emrekilic.web.tr

# Opsiyonel analitik (frontend build arg — birini kullanın)
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=emrekilic.web.tr

# ── Backend ──
API_PREFIX=api/v1
# Medya dosyalarının public URL kökü (yerel uploads kullanılıyorsa)
API_PUBLIC_URL=https://api.emrekilic.web.tr/api/v1
JWT_SECRET=degistir-guclu-bir-secret-uret
JWT_EXPIRES_IN=7d

# ── PostgreSQL ──
DATABASE_USER=portfolio
DATABASE_PASSWORD=degistir-guclu-sifre
DATABASE_NAME=portfolio
# İlk kurulumda tabloları oluşturur (migration eklenene kadar)
DATABASE_SYNCHRONIZE=true

# ── Google OAuth ──
# Authorized redirect URI: https://api.emrekilic.web.tr/api/v1/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://api.emrekilic.web.tr/api/v1/auth/google/callback
ALLOWED_ADMIN_EMAIL=ornek@gmail.com

# ── AWS S3 (opsiyonel — boş bırakılırsa yerel uploads kullanılır) ──
AWS_REGION=eu-north-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=portfolio-media
