# Backend ortam değişkenleri — docs/06-auth.md ve docs/02-backend.md
# Kopyala: cp .env.example .env

NODE_ENV=development
PORT=3001
API_PREFIX=api/v1

# PostgreSQL — yerel kurulumda doğrudan 5432; Docker + PgBouncer için 6432
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=
DATABASE_NAME=portfolio

# Redis — BullMQ, cache, Socket.io adapter
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT — admin oturum token'ları
JWT_SECRET=
JWT_EXPIRES_IN=7d

# Google OAuth — https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/api/v1/auth/google/callback

# Sadece bu e-posta admin paneline girebilir
ALLOWED_ADMIN_EMAIL=ornek@gmail.com

# Admin paneli CORS
ADMIN_URL=http://localhost:3002
FRONTEND_URL=http://localhost:3000

# AWS S3 — medya dosyaları
AWS_REGION=eu-north-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=portfolio-media

# Bull Board — kuyruk izleme paneli
BULL_BOARD_PATH=/admin/queues

# ── Production (Hetzner) ──
# FRONTEND_URL=https://emrekilic.web.tr
# ADMIN_URL=https://admin.emrekilic.web.tr
# GOOGLE_CALLBACK_URL=https://api.emrekilic.web.tr/api/v1/auth/google/callback
# Host portları: frontend 3100, admin 3101, api 3102 — deploy/README.md
