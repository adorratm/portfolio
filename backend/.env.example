# Backend ortam değişkenleri — docs/06-auth.md ve docs/02-backend.md
# Kopyala: cp .env.example .env

NODE_ENV=development
PORT=3001
API_PREFIX=api/v1

# PostgreSQL
# Yerel PostgreSQL (pgAdmin ile aynı): port 5432
# Docker Compose + PgBouncer: port 6432 (postgres container: portfolio / portfolio_dev)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=portfolio
DATABASE_PASSWORD=portfolio_dev
DATABASE_NAME=portfolio

# Redis — BullMQ, cache, Socket.io adapter
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT — admin oturum token'ları
JWT_SECRET=degistir-guclu-bir-secret-uret
JWT_EXPIRES_IN=7d

# Google OAuth — https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/api/v1/auth/google/callback

# Sadece bu e-posta admin paneline girebilir
ALLOWED_ADMIN_EMAIL=ornek@gmail.com

# Admin paneli CORS
ADMIN_URL=http://localhost:3002
FRONTEND_URL=http://localhost:3000

# AWS S3 — medya dosyaları
AWS_REGION=eu-central-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=portfolio-media-adorratm

# Bull Board — kuyruk izleme paneli
BULL_BOARD_PATH=/admin/queues
